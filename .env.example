# Van Overleven naar Leven — environment variables
# Copy to .env.local and fill in values. Never commit .env.local.
# See docs/OPEN_QUESTIONS.md for decisions still pending (auth, database, analytics).

# ─── Database / Auth (Supabase — see ADR-001, OPEN_QUESTION #6) ──────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Server-side only — never expose to the client
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── App ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Audio CDN (OPEN_QUESTION #13 — therapist audio) ─────────────────────────
# Base URL for therapist-recorded MP3s (Supabase Storage or Cloudflare R2)
# NEXT_PUBLIC_AUDIO_BASE_URL=https://your-bucket.supabase.co/storage/v1/object/public/audio

# ─── Analytics (optional — GDPR explicit consent required, OPEN_QUESTION #9) ─
# NEXT_PUBLIC_PLAUSIBLE_DOMAIN=vanoverlevennaarleven.nl

# ─── Push notifications (P2 — OPEN_QUESTION #7) ──────────────────────────────
# NEXT_PUBLIC_VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
