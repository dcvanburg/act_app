    "jsdom": "^29.1.1",
    "lint-staged": "^17.0.7",
    "postcss": "^8.4.49",
    "prettier": "^3.8.3",
    "tailwindcss": "^4.3.0",
    "tsx": "^4.19.2",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
